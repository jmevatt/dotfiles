#!/bin/sh
# labwc autostart — runs once at session start.
# To restart any of these without re-logging, kill and re-spawn manually.

# Wallpaper (Catppuccin Mocha radial gradient — generated by ImageMagick)
swaybg -i "$HOME/pictures/wallpapers/catppuccin-mocha-radial.png" -m fill >/dev/null 2>&1 &

# Multi-monitor output config
kanshi >/dev/null 2>&1 &

# Status bar
waybar >/dev/null 2>&1 &

# Notification center (replaces mako — fancier, history pane, dnd toggle)
swaync >/dev/null 2>&1 &

# Volume / brightness OSD — reads from /tmp/wobsock fifo
mkfifo /tmp/wobsock 2>/dev/null
rm -f /tmp/wobsock; mkfifo /tmp/wobsock
tail -f /tmp/wobsock | wob >/dev/null 2>&1 &

# Clipboard history — wrapper script skips entries that look like secrets
# (AWS keys, GH tokens, API keys, private keys, bare base64 blobs)
wl-paste --type text  --watch "$HOME/.config/labwc/cliphist-store-safe" >/dev/null 2>&1 &
wl-paste --type image --watch cliphist store >/dev/null 2>&1 &

# Idle: lock only — no DPMS power-off (NVIDIA wedge bug),
# no dim (brightnessctl doesn't drive external desktop monitors).
swayidle -w \
    timeout 300  'swaylock -f' \
    before-sleep 'swaylock -f' >/dev/null 2>&1 &

# Portal stack for screen-sharing / file pickers
/usr/lib/xdg-desktop-portal-wlr >/dev/null 2>&1 &
/usr/lib/xdg-desktop-portal      >/dev/null 2>&1 &

# Polkit agent for GUI auth prompts
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &

# Tray apps — show up in waybar's #tray
nm-applet --indicator >/dev/null 2>&1 &
blueman-applet >/dev/null 2>&1 &
