<?xml version="1.0" encoding="UTF-8"?>
<!--
  Right-click on the desktop pops this menu.
  See man labwc-menu(5) for syntax.
-->
<openbox_menu>

  <menu id="root-menu" label="Helicon">
    <item label="Terminal">
      <action name="Execute" command="wezterm" />
    </item>
    <item label="App Launcher">
      <action name="Execute" command="wofi --show drun" />
    </item>
    <item label="File Manager">
      <action name="Execute" command="wezterm start -- nnn" />
    </item>
    <item label="Browser">
      <action name="Execute" command="firefox" />
    </item>
    <separator />
    <menu id="ws-menu" label="Workspaces">
      <item label="ws1"><action name="GoToDesktop" to="1" /></item>
      <item label="ws2"><action name="GoToDesktop" to="2" /></item>
      <item label="ws3"><action name="GoToDesktop" to="3" /></item>
      <item label="ws4"><action name="GoToDesktop" to="4" /></item>
      <item label="ws5"><action name="GoToDesktop" to="5" /></item>
    </menu>
    <separator />
    <item label="Lock">
      <action name="Execute" command="swaylock" />
    </item>
    <item label="Reconfigure">
      <action name="Reconfigure" />
    </item>
    <item label="Exit labwc">
      <action name="Exit" />
    </item>
  </menu>

</openbox_menu>
