# Catppuccin Mocha titlebar theme — overrides whatever GTK theme is in <theme><name>
# Reference: man labwc-theme(5)

# Active window
window.active.title.bg.color: #1e1e2e
window.active.label.text.color: #cdd6f4
window.active.border.color: #cba6f7
window.active.handle.bg.color: #1e1e2e
window.active.button.unpressed.image.color: #cdd6f4
window.active.button.hover.image.color: #f5c2e7
window.active.button.iconify.unpressed.image.color: #cdd6f4
window.active.button.max.unpressed.image.color: #cdd6f4
window.active.button.close.unpressed.image.color: #f38ba8

# Inactive window
window.inactive.title.bg.color: #181825
window.inactive.label.text.color: #6c7086
window.inactive.border.color: #313244
window.inactive.handle.bg.color: #181825
window.inactive.button.unpressed.image.color: #6c7086

# Menu (right-click root menu)
menu.items.bg.color: #1e1e2e
menu.items.text.color: #cdd6f4
menu.items.active.bg.color: #cba6f7
menu.items.active.text.color: #1e1e2e
menu.separator.color: #45475a
menu.title.bg.color: #181825
menu.title.text.color: #cba6f7

# OSD (workspace switcher, window switcher)
osd.bg.color: #1e1e2e
osd.border.color: #cba6f7
osd.label.text.color: #cdd6f4

# Border / drop-shadow
border.width: 2
window.active.shadow.size: 12
window.inactive.shadow.size: 8

# Padding around titlebar text
padding.height: 6
padding.width: 8
