# mako — Catppuccin Mocha. Reload: makoctl reload
font=JetBrainsMono Nerd Font 11
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=10
padding=12
margin=8
default-timeout=6000
ignore-timeout=1
group-by=app-name
max-icon-size=48
icon-path=/usr/share/icons/Adwaita

anchor=top-right
layer=overlay
output=DP-4
sort=-time

[urgency=low]
border-color=#a6adc8
default-timeout=4000

[urgency=normal]
border-color=#cba6f7

[urgency=critical]
border-color=#f38ba8
text-color=#f38ba8
default-timeout=0

[app-name=Spotify]
border-color=#a6e3a1

[mode=do-not-disturb]
invisible=1

[mode=do-not-disturb app-name=notify-send]
invisible=0
