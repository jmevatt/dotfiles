# Secrets — never ever
.env
.env.*
*.key
*.pem
*_rsa
*_ed25519
*_ecdsa
id_*

# OS cruft
.DS_Store
Thumbs.db

# Editor cruft
*.swp
*.swo
*~
.vscode/
.idea/

# Stow working files
.stow-local-ignore.bak

# XFCE runtime / session / personal state
xfce4/.config/xfce4/notes/
xfce4/.config/xfce4/desktop/
xfce4/.config/xfce4/xfconf/xfce-perchannel-xml/*.bak-*
xfce4/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-notifyd.xml
