#!/usr/bin/env bash
# gdm-sync-monitors — copy ~/.config/monitors.xml into /var/lib/gdm/.config/
# so the GDM login screen respects the user's monitor layout (which displays
# are enabled, primary, scale, mode, rotation).
#
# GDM 45+ on systemd uses DynamicUser=yes — no static gdm user/group exists.
# The systemd state dir mechanism gives the dynamic gdm user read access to
# /var/lib/gdm/, so a world-readable file (mode 644, owned by root) works.
#
# Re-run this whenever you change your monitor config in Settings → Displays.
#
# Usage:  gdm-sync-monitors [--dry-run]
set -euo pipefail

SRC="$HOME/.config/monitors.xml"
DST="/var/lib/gdm/.config/monitors.xml"

DRY_RUN=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    -h|--help) sed -n '2,12p' "$0" | sed 's|^# *||'; exit 0 ;;
    *) printf 'unknown arg: %s\n' "$arg" >&2; exit 2 ;;
  esac
done

if [[ ! -f "$SRC" ]]; then
  printf 'error: %s not found — open Settings → Displays, change something, hit Apply.\n' "$SRC" >&2
  exit 1
fi

if [[ $DRY_RUN -eq 1 ]]; then
  printf 'would copy: %s → %s\n' "$SRC" "$DST"
  if [[ -f "$DST" ]]; then
    printf '\ndiff (existing → new):\n'
    sudo diff -u "$DST" "$SRC" || true
  else
    printf '\n(destination does not exist yet)\n'
  fi
  exit 0
fi

sudo install -d -m 755 "$(dirname "$DST")"
sudo install -m 644 "$SRC" "$DST"

printf '✓ synced %s → %s\n' "$SRC" "$DST"
printf '  GDM will use this layout on next login screen render.\n'
